---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Cta from '../../components/Cta.astro';
import { site } from '../../data/site';
---
<BaseLayout
  title="Benkovich Orthodontics Reviews | Annapolis & Chester, MD"
  description="Read real Benkovich Orthodontics reviews from Annapolis & Chester families — 5.0 stars across 200+ reviews. See why neighbors trust Dr. Benkovich.">

  <PageHero
    eyebrow="Patient reviews"
    title="Benkovich Orthodontics reviews"
    subtitle="A 5.0-star rating across 200+ reviews — from the Annapolis & Chester families who know us best. Here's what they have to say."
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Patient Info', href: '/patient-info/financial-information/' }, { label: 'Reviews', href: '/patient-info/testimonials/' }]} />

  <section class="section">
    <div class="container">
      <div class="center measure">
        <div class="stars rating-stars">★★★★★</div>
        <p class="eyebrow" style="margin-top:10px;">{site.rating} ★ on Google · {site.reviewCount} reviews</p>
        <h2>Trusted by families across Annapolis &amp; Chester</h2>
        <p class="lead">Since {site.established}, more than {site.patients} patients have trusted Dr. Benkovich with their smiles. We're grateful for every kind word — here are just a few. You can also <a href="/patient-info/before-and-after/">see real before-and-after smiles</a> from our patients.</p>
      </div>

      <div class="grid grid--3 reviews" style="margin-top:48px;">
        {site.reviews.map((r) => (
          <figure class="review">
            <div class="stars">★★★★★</div>
            <blockquote>{r.text}</blockquote>
            <figcaption>— {r.name}</figcaption>
          </figure>
        ))}
      </div>

      <div class="center" style="margin-top:46px;">
        <p>Want to see your own smile in good hands? Explore <a href="/braces/">braces</a> and <a href="/invisalign/">Invisalign</a>, or learn what to expect at your <a href="/patient-info/office-visits/">first office visit</a>.</p>
        <a href={site.booking} class="btn btn--primary btn--lg" style="margin-top:14px;">Schedule Your Free Exam</a>
      </div>
    </div>
  </section>

  <Cta heading="Ready to write your own success story?" />
</BaseLayout>

<style>
  .rating-stars { font-size: 2rem; letter-spacing: 6px; }
  .reviews { align-items: stretch; }
  .review { background: #fff; border-radius: var(--radius); padding: 28px 26px; margin: 0; box-shadow: var(--shadow-sm); border: 1px solid var(--line); display: flex; flex-direction: column; }
  .review blockquote { margin: 12px 0 16px; font-size: .98rem; color: var(--ink); line-height: 1.6; }
  .review figcaption { font-family: var(--font-head); font-weight: 700; color: var(--teal-700); margin-top: auto; }
</style>
