---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Cta from '../../components/Cta.astro';
import { site } from '../../data/site';
---
<BaseLayout
  title="New Patient Forms | Benkovich Orthodontics, Annapolis MD"
  description="Getting started at Benkovich Orthodontics is simple. Here's what to bring to your first visit in Annapolis or Chester, MD — then request your free first exam, with plans from $184/month.">

  <PageHero
    eyebrow="Patient forms"
    title="New patient forms"
    subtitle="We keep new-patient paperwork quick and simple, so your first visit is all about your smile."
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Patient Info', href: '/patient-info/financial-information/' }, { label: 'Patient Forms', href: '/patient-info/patient-forms/' }]} />

  <section class="section">
    <div class="container measure">
      <p class="eyebrow">Before your first visit</p>
      <h2>Getting started is simple</h2>
      <p>We want your first visit to be about you, not paperwork. When you book your free first exam, our friendly team will walk you through everything you need — so check-in is smooth and fast, with more time to talk smiles with Dr. Benkovich.</p>

      <div class="forms-card card">
        <h3>What to bring to your first visit</h3>
        <ul class="forms-list">
          <li>A photo ID</li>
          <li>Your dental insurance card, if you have coverage</li>
          <li>Any recent X-rays or a referral, if you have them</li>
        </ul>
        <a href={site.booking} class="btn btn--primary btn--lg">Request Your Free Exam</a>
      </div>

      <p style="margin-top:32px;">Have questions before you come in? Just <a href="/contact-us/">give us a call</a> — we're happy to help. Curious what to expect when you arrive? See our quick walkthrough of <a href="/patient-info/office-visits/">your first office visit</a>.</p>
    </div>
  </section>

  <Cta heading="Almost ready — let's get you scheduled" />
</BaseLayout>

<style>
  .forms-card { padding: 34px 30px; margin-top: 30px; text-align: center; background: var(--mint); border-color: transparent; }
  .forms-card h3 { color: var(--teal-700); margin-bottom: 10px; }
  .forms-card p { color: var(--slate); max-width: 520px; margin: 0 auto 22px; }
  .forms-list { list-style: none; padding: 0; margin: 0 auto 24px; max-width: 420px; text-align: left; }
  .forms-list li { padding: 9px 0 9px 28px; position: relative; color: var(--slate); border-bottom: 1px solid rgba(12,51,84,.08); }
  .forms-list li:last-child { border-bottom: 0; }
  .forms-list li::before { content: '✓'; position: absolute; left: 0; color: var(--teal); font-weight: 800; }
</style>
