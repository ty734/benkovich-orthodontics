---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Cta from '../../../components/Cta.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate } = post.data;
---
<BaseLayout title={`${title} | Benkovich Orthodontics`} description={description}>
  <article class="post">
    <div class="container post__inner">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="crumbs__sep">/</span><a href="/about/blog/">Blog</a>
      </nav>
      <h1>{title}</h1>
      {pubDate && <p class="post__date">{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
      <div class="prose">
        <Content />
      </div>
      <p class="post__back"><a href="/about/blog/">← Back to all articles</a></p>
    </div>
  </article>
  <Cta heading="Have questions about your smile?" text="A free first exam with Dr. Benkovich is the easiest way to get real answers — no pressure, no obligation." />
</BaseLayout>

<style>
  .post { padding: clamp(34px, 5vw, 60px) 0 clamp(50px, 7vw, 80px); }
  .post__inner { max-width: 760px; }
  .crumbs { font-size: .85rem; color: var(--slate); margin-bottom: 18px; }
  .crumbs a { color: var(--slate); font-weight: 600; }
  .crumbs a:hover { color: var(--teal-600); }
  .crumbs__sep { margin: 0 8px; opacity: .5; }
  .post h1 { margin-bottom: 10px; }
  .post__date { color: var(--slate); font-size: .92rem; margin-bottom: 28px; }
  .post__back { margin-top: 36px; font-family: var(--font-head); font-weight: 700; }

  .prose { font-size: 1.08rem; line-height: 1.75; color: var(--ink); }
  .prose :global(h2) { font-size: 1.7rem; margin: 1.8em 0 .5em; }
  .prose :global(h3) { font-size: 1.3rem; margin: 1.5em 0 .4em; }
  .prose :global(p) { margin: 0 0 1.1em; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.2em; padding-left: 1.4em; }
  .prose :global(li) { margin-bottom: .5em; }
  .prose :global(a) { color: var(--teal-600); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(a:hover) { color: var(--teal-700); }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(img) { border-radius: var(--radius); margin: 1.4em 0; }
  .prose :global(blockquote) { border-left: 4px solid var(--teal); padding-left: 18px; margin: 1.4em 0; color: var(--slate); font-style: italic; }
  .prose :global(h2:first-child), .prose :global(h3:first-child) { margin-top: 0; }
</style>
