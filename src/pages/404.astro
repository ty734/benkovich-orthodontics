---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---
<BaseLayout
  title="Page Not Found | Benkovich Orthodontics"
  description="That page couldn't be found. Explore braces, Invisalign, our Annapolis & Chester offices, or book a free first exam with Dr. Benkovich."
  noindex={true}>

  <section class="section notfound">
    <div class="container center measure">
      <p class="eyebrow">Error 404</p>
      <h1>We couldn't find that page</h1>
      <p>The page you're looking for may have moved or no longer exists — but your confident smile is still right this way. Here are a few good places to go next:</p>

      <div class="notfound__links">
        <a href="/" class="btn btn--primary">Back to Home</a>
        <a href={site.booking} class="btn btn--ghost">Book a Free Exam</a>
      </div>

      <div class="notfound__grid">
        <a href="/braces/">Braces</a>
        <a href="/invisalign/">Invisalign®</a>
        <a href="/early-orthodontics/">Early Orthodontics</a>
        <a href="/adult-orthodontics/">Adult Orthodontics</a>
        <a href="/locations/orthodontist-annapolis-md/">Annapolis Office</a>
        <a href="/locations/orthodontist-chester-md/">Chester / Kent Island Office</a>
        <a href="/about/meet-dr-benkovich/">Meet Dr. Benkovich</a>
        <a href="/about/blog/">Blog</a>
      </div>

      <p class="notfound__call">Prefer to talk to someone? Call our Annapolis office at <a href={site.locations[0].phoneHref}>{site.locations[0].phone}</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound { padding: clamp(48px, 8vw, 96px) 0; }
  .notfound h1 { margin: 6px 0 14px; }
  .notfound > .container > p { color: var(--slate); }
  .notfound__links { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin: 28px 0 8px; }
  .notfound__grid { display: flex; flex-wrap: wrap; gap: 10px 22px; justify-content: center; margin: 30px 0 0; }
  .notfound__grid a { font-family: var(--font-head); font-weight: 700; color: var(--teal-700); }
  .notfound__grid a:hover { color: var(--teal); }
  .notfound__call { margin-top: 30px; font-size: .95rem; }
  .notfound__call a { font-weight: 700; color: var(--teal); }
</style>
