---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FaqBlock from '../components/FaqBlock.astro';
import Cta from '../components/Cta.astro';
import PhotoFeature from '../components/PhotoFeature.astro';
import { site } from '../data/site';

const loc = site.locations[0];

const faqs = [
  { q: 'Do you offer clear braces at your Annapolis office?', a: 'Yes. Clear (ceramic) braces are one of our most popular options for adults and older teens at our Annapolis office. Dr. Benkovich will confirm they’re a good fit for your bite at your free first exam.' },
  { q: 'Are clear braces noticeable?', a: 'Far less than metal. The brackets are tooth-colored and blend into your smile, so they stay subtle in conversation and photos — a favorite for professionals and image-conscious teens who still want the reliability of braces.' },
  { q: 'Do clear braces cost more than metal in Annapolis?', a: 'Clear braces typically run a little more than metal because of the ceramic materials, but the difference is modest. Both start at $184/month with transparent, upfront pricing and most insurance accepted — your exact figure comes from a free exam.' },
  { q: 'Clear braces or Invisalign — which is better for me?', a: 'Both are discreet. Clear braces stay on and handle a wide range of corrections; Invisalign is removable for meals. As a specialty-trained orthodontist, Dr. Benkovich will give you an honest recommendation after reviewing your 3D iTero scan.' },
  { q: 'How do I get started?', a: 'Book a free first exam at our Annapolis office. It includes an exam and digital X-ray, Dr. Benkovich reviews your smile in plain language, and many patients can start the same day — no pressure, no obligation.' },
];
---
<BaseLayout
  title="Clear Braces in Annapolis, MD | Benkovich Orthodontics"
  description="Discreet clear (ceramic) braces in Annapolis, MD from a specialty-trained orthodontist. Flexible plans from $184/month and a free first exam. Book today.">

  <PageHero
    eyebrow="Clear Braces · Annapolis, MD"
    title="Clear Braces in Annapolis, MD"
    subtitle="Tooth-colored, low-profile braces that straighten your smile without the spotlight — planned on a 3D scan by a specialty-trained orthodontist, starting at $184/month with a free first exam."
    image="/images/first-day-braces.webp"
    imageAlt="A happy Benkovich Orthodontics braces patient on their first day at the Annapolis, MD office"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Braces', href: '/braces/' }, { label: 'Clear Braces — Annapolis', href: '/clear-braces-annapolis-md/' }]} />

  <section class="section">
    <div class="container measure">
      <p class="eyebrow">Discreet by design</p>
      <h2>Straighten your smile, quietly</h2>
      <p>Clear (ceramic) braces work exactly like traditional <a href="/braces/">braces</a> — brackets and wires gently guiding your teeth into place — but the brackets are tooth-colored, so they blend in instead of standing out. For Annapolis adults and older teens who want a subtle look without going fully removable, they’re an ideal middle ground.</p>
      <p>What makes them work here isn’t the hardware — it’s who’s behind it. Dr. Benkovich is a specialty-trained orthodontist (not a general dentist offering braces on the side) who has personally treated 10,000+ local smiles since 1993, and he plans every case from a 3D iTero scan rather than guesswork.</p>
    </div>
  </section>

  <PhotoFeature
    image="/images/itero-scan.webp"
    alt="A 3D iTero digital scan used to plan clear braces treatment at Benkovich Orthodontics in Annapolis, MD"
    eyebrow="See what we see"
    heading="Your plan, mapped in 3D"
    body="No messy impressions — a quick digital scan lets Dr. Benkovich plan your clear-braces treatment precisely and explain it in plain language, so you know exactly what to expect before day one."
    ratio="3/4"
    tone="mint"
    reverse />

  <section class="section">
    <div class="container measure">
      <p class="eyebrow">Clear vs. metal</p>
      <h2>Not sure clear is the right call?</h2>
      <p>Clear braces look great, but metal braces are tougher and more economical — and the right answer depends on your smile, your budget, and your day-to-day life. We lay it all out honestly in our <a href="/clear-braces-vs-metal/">clear braces vs. metal braces comparison</a>, or prefer something fully removable? <a href="/invisalign/">Explore Invisalign →</a></p>
      <p style="margin-top:14px;">Either way, we keep it affordable with flexible plans <strong>starting at {site.offer.price}/month</strong>, clear upfront costs, and most insurance accepted.</p>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container measure">
      <p class="eyebrow">Right around the corner</p>
      <h2>Clear braces close to home in Annapolis</h2>
      <p>Our Annapolis office is easy to reach from downtown Annapolis and the Naval Academy, Eastport, Parole, and nearby communities like Severna Park, Arnold, and Edgewater. See office details, directions, and hours on our <a href="/locations/orthodontist-annapolis-md/">Annapolis office page</a>, or call us at <a href={loc.phoneHref}>{loc.phone}</a>.</p>
      <p style="margin-top:14px;">On the other side of the bay? We also offer <a href="/clear-braces-chester-md/">clear braces in Chester / Kent Island</a>.</p>
    </div>
  </section>

  <FaqBlock items={faqs} heading="Clear braces in Annapolis — common questions" />

  <Cta heading="Ready for a subtler way to straighten?" />
</BaseLayout>
