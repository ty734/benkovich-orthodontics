---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FaqBlock from '../components/FaqBlock.astro';
import Cta from '../components/Cta.astro';
import { site } from '../data/site';

const faqs = [
  { q: 'Why do I need a retainer after braces or Invisalign?', a: 'Teeth naturally want to drift back toward their old positions, especially in the first months after treatment. A retainer holds your new smile in place so all that work keeps looking great for years to come.' },
  { q: 'What types of retainers are there?', a: 'The most common are clear (Essix) retainers that fit invisibly over your teeth, and Hawley retainers — a durable wire-and-acrylic design that’s easy to adjust. Some patients have a thin bonded wire behind the front teeth. Dr. Benkovich will recommend what fits your smile best.' },
  { q: 'How long do I have to wear my retainer?', a: 'Most patients wear their retainer full-time for a short period, then shift to nights only. Because teeth can shift for life, wearing it at night long-term is the best way to protect your results. We’ll give you clear, personalized guidance.' },
  { q: 'What if I lose or break my retainer?', a: 'It happens — don’t worry. Just call us and we’ll arrange an easy replacement so your smile stays protected. Wearing a damaged or ill-fitting retainer can let teeth shift, so reach out sooner rather than later.' },
  { q: 'How do I clean and care for my retainer?', a: 'Rinse it after wearing, brush it gently with a soft toothbrush, and keep it in its case when it’s not in your mouth. Avoid hot water, which can warp it. A clean retainer is a comfortable, long-lasting retainer.' },
];
---
<BaseLayout
  title="Retainers in Annapolis & Chester, MD | Benkovich Orthodontics"
  description="Clear & Hawley retainers in Annapolis & Chester, MD to protect your new smile. Easy replacements, plans from $184/month and a free first exam. Book today.">

  <PageHero
    eyebrow="Retainers"
    title="Retainers in Annapolis & Chester, MD"
    subtitle="The simple, important step that protects all your hard work. Comfortable clear and Hawley retainers, easy replacements, and care your neighbors have trusted for over 30 years."
    image="/images/svc-retainers.jpg"
    imageAlt="A smiling older teen holding a clear retainer at Benkovich Orthodontics in Annapolis, MD"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Retainers', href: '/retainers/' }]} />

  <section class="section">
    <div class="container measure">
      <p class="eyebrow">The finishing touch</p>
      <h2>A retainer protects everything you worked for</h2>
      <p>Finishing <a href="/braces/">braces</a> or <a href="/invisalign/">Invisalign</a> is a great feeling — and a retainer is what keeps that feeling looking its best. After treatment, teeth naturally want to drift back toward where they started, especially in those first months. A retainer gently holds your new smile in place so your results stay beautiful and straight.</p>
      <p>Think of it as the small, easy habit that protects a big investment. Dr. Benkovich will fit you with a comfortable retainer and give you clear, simple guidance on wearing it — so your smile stays exactly the way you love it.</p>
    </div>
  </section>

  <section class="section section--mint">
    <div class="container">
      <div class="center measure">
        <p class="eyebrow">Your options</p>
        <h2>Types of retainers we offer</h2>
      </div>
      <div class="grid grid--3" style="margin-top:42px;">
        <div class="card feature">
          <h3>Clear (Essix) Retainers</h3>
          <p>A thin, transparent retainer that slips invisibly over your teeth — discreet, lightweight, and popular with teens and adults alike.</p>
        </div>
        <div class="card feature">
          <h3>Hawley Retainers</h3>
          <p>The classic wire-and-acrylic design. Durable, adjustable, and long-lasting, with a custom-fit base that’s comfortable to wear.</p>
        </div>
        <div class="card feature">
          <h3>Easy Replacements</h3>
          <p>Lost or broke yours? Just call. We make replacements simple so your smile is never left unprotected for long.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container measure">
      <p class="eyebrow">Wearing your retainer</p>
      <h2>Simple guidance that keeps your smile straight</h2>
      <p>Most patients wear their retainer full-time at first, then move to wearing it just at night. Because teeth can shift slowly throughout life, keeping up with nighttime wear long-term is the surest way to protect your results — and it quickly becomes second nature.</p>
      <p>Caring for it is easy, too: rinse it after wearing, brush it gently, store it in its case, and keep it away from hot water so it holds its shape. If your retainer ever feels tight or stops fitting well, reach out — that’s usually a sign teeth are starting to move and we can help right away.</p>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container measure">
      <p class="eyebrow">What to expect</p>
      <h2>Getting your retainer, step by step</h2>
      <ol class="steps">
        <li><strong>A quick, comfortable fitting.</strong> We take a precise scan or impression so your retainer fits just right.</li>
        <li><strong>Your custom retainer.</strong> Dr. Benkovich recommends the type that best protects your smile.</li>
        <li><strong>Clear wear instructions.</strong> We’ll show you exactly how and when to wear it for lasting results.</li>
        <li><strong>Easy check-ins.</strong> We make sure the fit stays comfortable and your smile stays on track.</li>
        <li><strong>Replacements when you need them.</strong> Lost or damaged? A simple call gets you a new one fast.</li>
      </ol>
      <p style="margin-top:22px;">New to treatment? Explore <a href="/braces/">braces</a> and <a href="/invisalign/">Invisalign</a>, or see our <a href="/patient-info/financial-information/">financial &amp; insurance options</a>.</p>
    </div>
  </section>

  <FaqBlock items={faqs} heading="Retainer questions, answered" />

  <Cta heading="Ready to protect your new smile?" />
</BaseLayout>

<style>
  .feature { padding: 28px 26px; }
  .feature h3 { margin-bottom: 10px; }
  .feature p { color: var(--slate); margin: 0; }
  .steps { counter-reset: step; list-style: none; padding: 0; margin: 22px 0 0; }
  .steps li { position: relative; padding: 0 0 22px 52px; border-left: 2px solid var(--line); margin-left: 16px; }
  .steps li::before { counter-increment: step; content: counter(step); position: absolute; left: -17px; top: -2px;
    width: 32px; height: 32px; border-radius: 50%; background: var(--teal); color: #fff; font-family: var(--font-head); font-weight: 800; display: flex; align-items: center; justify-content: center; font-size: .95rem; }
  .steps li:last-child { border-left-color: transparent; }
</style>
