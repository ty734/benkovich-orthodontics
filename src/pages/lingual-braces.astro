---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FaqBlock from '../components/FaqBlock.astro';
import Cta from '../components/Cta.astro';
import { site } from '../data/site';

const faqs = [
  { q: 'What are lingual braces?', a: 'Lingual braces are traditional braces placed on the inside (tongue side) of your teeth rather than the front. They straighten teeth the same way standard braces do, but they’re hidden from view — so most people won’t know you’re wearing them.' },
  { q: 'Are lingual braces completely invisible?', a: 'From the outside, they’re very discreet — because the brackets sit behind your teeth, they’re hidden during everyday conversation and photos. They’re one of the most concealed options available for people who want to straighten their smile without it showing.' },
  { q: 'Do lingual braces affect speech?', a: 'There can be a short adjustment period — some people notice a slight lisp or extra tongue awareness in the first week or two. For most, speech returns to normal as the tongue adapts. We’ll give you tips to ease the transition.' },
  { q: 'Who is a good candidate for lingual braces?', a: 'Adults and older teens who want a hidden option and aren’t drawn to clear aligners often consider them. Whether they’re right for you depends on your specific bite and goals — Dr. Benkovich can advise at your free exam, and may suggest an option that’s an even better fit.' },
  { q: 'How much do discreet braces cost in Annapolis & Chester?', a: 'Every smile is different, so a free exam gives you an exact figure. We keep discreet treatment affordable with flexible monthly plans starting at $184/month, transparent pricing, and most insurance accepted.' },
  { q: 'What other discreet options are available?', a: 'Plenty. Clear (ceramic) braces use tooth-colored brackets that blend in, and Invisalign straightens with virtually invisible, removable aligners. For many patients these are a comfortable, convenient way to straighten discreetly — we’ll compare them with you.' },
];
---
<BaseLayout
  title="Lingual Braces in Annapolis & Chester, MD | Benkovich Orthodontics"
  description="Lingual braces hidden behind your teeth in Annapolis & Chester, MD. Discreet straightening, who they suit & considerations — from $184/month, free first exam.">

  <PageHero
    eyebrow="Lingual Braces"
    title="Lingual Braces in Annapolis & Chester, MD"
    subtitle="Braces placed behind your teeth — straightening your smile while staying out of sight. Here’s who they suit and what to consider, with discreet care starting at $184/month and a free first exam."
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Braces', href: '/braces/' }, { label: 'Lingual Braces', href: '/lingual-braces/' }]} />

  <section class="section">
    <div class="container measure">
      <p class="eyebrow">Hidden from view</p>
      <h2>Straighten your smile, discreetly</h2>
      <p>Lingual braces are simply traditional <a href="/braces/">braces</a> placed on the inside surface of your teeth, facing the tongue, instead of the front. They move teeth the same proven way standard braces do — but because the brackets sit behind your teeth, they stay hidden during everyday conversation and photos.</p>
      <p>For people who want their treatment to be as invisible as possible, that out-of-sight design is the whole appeal. And whichever discreet path you choose, we keep things affordable with flexible plans <strong>starting at {site.offer.price}/month</strong>, transparent pricing, and most insurance accepted.</p>
    </div>
  </section>

  <section class="section section--mint">
    <div class="container">
      <div class="center measure">
        <p class="eyebrow">Worth knowing</p>
        <h2>The trade-offs to consider</h2>
      </div>
      <div class="grid grid--3" style="margin-top:42px;">
        <div class="card feature">
          <h3>Truly out of sight</h3>
          <p>Because the brackets sit behind your teeth, lingual braces are among the most concealed ways to straighten — ideal if you’d rather your treatment not show.</p>
        </div>
        <div class="card feature">
          <h3>An adjustment period</h3>
          <p>Your tongue needs a little time to get used to brackets on the inside. Some people notice a brief lisp or tenderness early on that typically eases within a week or two.</p>
        </div>
        <div class="card feature">
          <h3>Extra care at home</h3>
          <p>Brushing and flossing behind the teeth takes a bit more attention. We’ll show you simple techniques and tools to keep everything clean and healthy.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center measure">
        <p class="eyebrow">Compare discreet options</p>
        <h2>Other ways to straighten subtly</h2>
      </div>
      <div class="grid grid--3" style="margin-top:42px;">
        <a href="/clear-braces-vs-metal/" class="card feature feature--link"><h3>Clear vs. Metal Braces →</h3><p>See how tooth-colored ceramic braces compare with classic metal.</p></a>
        <a href="/invisalign/" class="card feature feature--link"><h3>Invisalign →</h3><p>Virtually invisible, removable aligners — a favorite for adults and teens.</p></a>
        <a href="/braces/" class="card feature feature--link"><h3>All Braces Options →</h3><p>Explore the full range of braces we offer for every age and goal.</p></a>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container measure">
      <p class="eyebrow">Is it right for you?</p>
      <h2>Let’s find your best discreet option</h2>
      <p>Hidden braces aren’t the right fit for every smile — and that’s exactly why a free first exam matters. Dr. Benkovich will look at your bite, talk through your goals, and recommend the discreet option he’d choose for his own family, whether that’s lingual braces, clear braces, or Invisalign. No pressure, no obligation.</p>
      <p style="margin-top:22px;">Curious about cost? See our <a href="/patient-info/financial-information/">financial &amp; insurance options</a>, or visit us in <a href="/locations/orthodontist-annapolis-md/">Annapolis</a> or <a href="/locations/orthodontist-chester-md/">Chester</a>.</p>
    </div>
  </section>

  <FaqBlock items={faqs} heading="Lingual braces, answered" />

  <Cta heading="Want a discreet way to straighten your smile?" />
</BaseLayout>

<style>
  .feature { padding: 28px 26px; }
  .feature h3 { margin-bottom: 10px; }
  .feature p { color: var(--slate); margin: 0; }
  .feature--link { color: var(--ink); transition: .2s; display: block; }
  .feature--link:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .feature--link h3 { color: var(--teal-700); }
</style>
