---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
---
<BaseLayout
  title="Thank You | Benkovich Orthodontics"
  description="Thank you for your appointment request. The Benkovich Orthodontics team will reach out within one business day to confirm your free first exam."
  noindex>

  <PageHero
    eyebrow="Request received"
    title="Thank you — we've got your request!"
    subtitle="We're so glad you reached out. A member of our friendly team will be in touch within one business day to find a time that works for your free first exam."
    showCta={false} />

  <section class="section">
    <div class="container measure">
      <p class="eyebrow">What happens next</p>
      <h2>Here's what to expect</h2>
      <ol class="next-steps">
        <li><strong>We'll reach out.</strong> Our team will call or email you within one business day to confirm your preferred location and schedule your free exam.</li>
        <li><strong>Your free first exam.</strong> You'll meet Dr. Benkovich for a relaxed, no-pressure visit. He'll review your smile and explain your options clearly — including flexible payment plans starting at $184/month.</li>
        <li><strong>A plan that fits you.</strong> If treatment is right for you, we'll walk through everything up front, with honest pricing and most insurance accepted. There's never any obligation.</li>
      </ol>

      <div class="confirm-urgent">
        <p>Need to reach us sooner, or have a question in the meantime? We're happy to help.</p>
        <p class="confirm-phones">
          <a href={site.locations[0].phoneHref}>{site.locations[0].name}: {site.locations[0].phone}</a>
          <span class="confirm-sep" aria-hidden="true">·</span>
          <a href={site.locations[1].phoneHref}>{site.locations[1].name.split(' / ')[0]}: {site.locations[1].phone}</a>
        </p>
      </div>

      <div class="confirm-links">
        <p>While you wait, get to know us a little better:</p>
        <ul>
          <li><a href="/about/meet-dr-benkovich/">Meet Dr. Benkovich</a> — the doctor your neighbors have trusted for over 30 years.</li>
          <li><a href="/patient-info/office-visits/">What to expect at your office visits</a> — a friendly look at how we make every visit easy.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .next-steps { counter-reset: step; list-style: none; padding: 0; margin: 22px 0 0; }
  .next-steps li { position: relative; padding: 0 0 22px 52px; border-left: 2px solid var(--line); margin-left: 16px; }
  .next-steps li::before { counter-increment: step; content: counter(step); position: absolute; left: -17px; top: -2px;
    width: 32px; height: 32px; border-radius: 50%; background: var(--teal); color: #fff; font-family: var(--font-head); font-weight: 800; display: flex; align-items: center; justify-content: center; font-size: .95rem; }
  .next-steps li:last-child { border-left-color: transparent; }
  .confirm-urgent { background: var(--mint); border-radius: var(--radius); padding: 26px 28px; margin: 34px 0; text-align: center; }
  .confirm-urgent p { margin: 0 0 6px; color: var(--slate); }
  .confirm-phones { font-family: var(--font-head); font-weight: 700; margin: 0 !important; }
  .confirm-phones a { color: var(--teal-700); }
  .confirm-sep { margin: 0 10px; color: var(--line); }
  .confirm-links ul { margin: 12px 0 0; padding-left: 20px; }
  .confirm-links li { margin-bottom: 10px; color: var(--slate); }
</style>
