---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
import { site } from '../data/site';
---
<BaseLayout
  title="Schedule a Free Exam | Appointment Request | Benkovich Orthodontics"
  description="Request your free first exam at Benkovich Orthodontics in Annapolis or Chester, MD. A relaxed, no-pressure visit with Dr. Benkovich — plans starting at $184/month.">

  <section class="appt">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="crumbs__sep">/</span><a href="/appointment-request/">Appointment Request</a>
      </nav>

      <div class="appt__grid">
        <!-- LEFT: invitation + reasons + call option -->
        <div class="appt__info">
          <p class="eyebrow">Free First Exam</p>
          <h1>Schedule your free exam</h1>
          <p class="lead">Take the first step toward a confident new smile. Tell us a little about yourself and our team will reach out to find a time that works — no pressure, no obligation, and your first exam is on us.</p>

          <ul class="appt__points">
            <li><strong>Your first exam is free</strong> — a relaxed visit to meet Dr. Benkovich</li>
            <li><strong>Plans starting at {site.offer.price}/month</strong>, and we work with most insurance</li>
            <li><strong>We’ll be in touch within one business day</strong></li>
          </ul>

          <div class="appt__call">
            <span class="appt__call-label">Prefer to talk now?</span>
            <a href={site.locations[0].phoneHref}>Annapolis — {site.locations[0].phone}</a>
            <a href={site.locations[1].phoneHref}>Chester — {site.locations[1].phone}</a>
          </div>

          <p class="appt__trust">{site.patients} happy patients · {site.reviewCount} 5-star reviews · caring for smiles since {site.established}</p>
        </div>

        <!-- RIGHT: the GoHighLevel lead form -->
        <div class="appt__formcol">
          <!--
            OrthoBoost → GoHighLevel lead form. Hidden attribution fields + the inline
            script below match the standard OrthoBoost field set (utm_*, gclid, fbclid, offer, page).
            On submit the script POSTs JSON to the GHL inbound webhook, then redirects to
            /appointment-request-confirmation/ (the Google Ads conversion page).
            >>> REPLACE the data-webhook value with the client's real GHL inbound webhook URL. <<<
          -->
          <form
            id="appointment-form"
            class="ob-form card"
            method="POST"
            action="#"
            data-webhook="REPLACE_WITH_GHL_WEBHOOK"
            data-confirm="/appointment-request-confirmation/"
            novalidate>

            <p class="ob-form__heading">Request your appointment</p>

            <div class="field-row">
              <div class="field">
                <label for="firstName">First name <span class="req" aria-hidden="true">*</span></label>
                <input type="text" id="firstName" name="firstName" autocomplete="given-name" required />
              </div>
              <div class="field">
                <label for="lastName">Last name <span class="req" aria-hidden="true">*</span></label>
                <input type="text" id="lastName" name="lastName" autocomplete="family-name" required />
              </div>
            </div>

            <div class="field-row">
              <div class="field">
                <label for="email">Email <span class="req" aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" autocomplete="email" required />
              </div>
              <div class="field">
                <label for="phone">Phone <span class="req" aria-hidden="true">*</span></label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" required />
              </div>
            </div>

            <div class="field-row">
              <div class="field">
                <label for="location">Preferred location</label>
                <select id="location" name="location">
                  <option value="Annapolis">Annapolis, MD</option>
                  <option value="Chester">Chester / Kent Island, MD</option>
                </select>
              </div>
              <div class="field">
                <label for="reason">I'm interested in</label>
                <select id="reason" name="reason">
                  <option value="Braces">Braces</option>
                  <option value="Invisalign">Invisalign®</option>
                  <option value="Other">Other / Not sure yet</option>
                </select>
              </div>
            </div>

            <div class="field">
              <label for="message">Anything you'd like us to know? <span class="opt">(optional)</span></label>
              <textarea id="message" name="message" rows="3" placeholder="Tell us a bit about what you're hoping for, or any questions you have."></textarea>
            </div>

            <div class="consent">
              <input type="checkbox" id="smsConsent" name="smsConsent" value="yes" />
              <label for="smsConsent">By checking this box, I consent to receive appointment, marketing, and informational text messages from Benkovich Orthodontics at the number provided. Consent is not a condition of any purchase. Message and data rates may apply. Message frequency varies. Reply STOP to opt out or HELP for help. See our <a href="/privacy-policy/">Privacy Policy</a> and <a href="/terms-and-conditions/">Terms &amp; Conditions</a>.</label>
            </div>

            <!-- Hidden attribution fields — populated from the URL on load by the script below. -->
            <input type="hidden" name="utm_source" value="" />
            <input type="hidden" name="utm_medium" value="" />
            <input type="hidden" name="utm_campaign" value="" />
            <input type="hidden" name="utm_term" value="" />
            <input type="hidden" name="utm_content" value="" />
            <input type="hidden" name="gclid" value="" />
            <input type="hidden" name="fbclid" value="" />
            <input type="hidden" name="offer" value="" />
            <input type="hidden" name="page" value="" />

            <button type="submit" class="btn btn--primary btn--lg">Request My Free Exam</button>
            <p class="form-note">We respect your privacy and will never share your information. Your first exam is always free.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Cta heading="Questions before you book?" text="Give us a call or send your request — our friendly team is happy to walk you through everything, from treatment options to flexible payment plans starting at $184/month." />
</BaseLayout>

<script is:inline>
  (function () {
    var form = document.getElementById('appointment-form');
    if (!form) return;

    // --- Capture URL attribution params into the hidden fields on load. ---
    var params = new URLSearchParams(window.location.search);
    var fields = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid', 'offer'];
    fields.forEach(function (key) {
      var val = params.get(key);
      if (val) {
        var el = form.querySelector('input[name="' + key + '"]');
        if (el) el.value = val;
      }
    });
    var pageEl = form.querySelector('input[name="page"]');
    if (pageEl) pageEl.value = window.location.pathname;

    // --- Submit: POST JSON to the GHL webhook, then redirect to the confirmation page. ---
    form.addEventListener('submit', function (ev) {
      ev.preventDefault();

      var first = (document.getElementById('firstName').value || '').trim();
      var last = (document.getElementById('lastName').value || '').trim();
      var email = (document.getElementById('email').value || '').trim();
      var phone = (document.getElementById('phone').value || '').trim();

      if (!first) { document.getElementById('firstName').focus(); return; }
      if (!last) { document.getElementById('lastName').focus(); return; }
      if (!email) { document.getElementById('email').focus(); return; }
      if (!phone) { document.getElementById('phone').focus(); return; }

      var data = {
        'Full Name': (first + ' ' + last).trim(),
        'Email': email,
        'Phone': phone,
        'Location': (document.getElementById('location') || {}).value || '',
        'Reason': (document.getElementById('reason') || {}).value || '',
        'Message': (document.getElementById('message') || {}).value || '',
        'SMS Consent': document.getElementById('smsConsent').checked ? 'yes' : 'no'
      };
      ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid', 'offer', 'page'].forEach(function (key) {
        var el = form.querySelector('input[name="' + key + '"]');
        var payloadKey = key === 'offer' ? 'Offer' : key;
        data[payloadKey] = el ? el.value : '';
      });

      var webhook = form.getAttribute('data-webhook');
      var confirm = form.getAttribute('data-confirm') || '/appointment-request-confirmation/';
      var btn = form.querySelector('button[type=submit]');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }

      function done() { window.location.href = confirm; }

      if (webhook && webhook !== 'REPLACE_WITH_GHL_WEBHOOK') {
        fetch(webhook, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
          keepalive: true
        }).then(done).catch(done);
      } else {
        done();
      }
    });
  })();
</script>

<style>
  .appt { background: radial-gradient(120% 120% at 88% 0%, var(--mint) 0%, #fff 56%); padding: clamp(28px, 4vw, 48px) 0 clamp(54px, 7vw, 88px); }
  .crumbs { font-size: .85rem; color: var(--slate); margin-bottom: 22px; }
  .crumbs a { color: var(--slate); font-weight: 600; }
  .crumbs a:hover { color: var(--teal-600); }
  .crumbs__sep { margin: 0 8px; opacity: .5; }

  .appt__grid { display: grid; gap: 40px; align-items: start; }
  @media (min-width: 940px) { .appt__grid { grid-template-columns: 0.82fr 1.18fr; gap: 60px; } }

  /* Left column */
  .appt__info h1 { margin: 12px 0 16px; }
  .appt__points { list-style: none; padding: 0; margin: 26px 0; }
  .appt__points li { padding: 10px 0 10px 32px; position: relative; color: var(--ink); border-bottom: 1px solid var(--line); }
  .appt__points li:last-child { border-bottom: 0; }
  .appt__points li::before { content: '✓'; position: absolute; left: 0; color: var(--teal); font-weight: 800; }
  .appt__points strong { color: var(--ink); }
  .appt__call { background: #fff; border: 1px solid var(--line); box-shadow: var(--shadow-sm); border-radius: 16px; padding: 20px 22px; margin: 26px 0 22px; display: flex; flex-direction: column; gap: 5px; }
  .appt__call-label { color: var(--slate); font-weight: 600; font-size: .92rem; margin-bottom: 3px; }
  .appt__call a { font-family: var(--font-head); font-weight: 800; font-size: 1.18rem; color: var(--teal-700); }
  .appt__call a:hover { color: var(--navy); }
  .appt__trust { color: var(--slate); font-size: .9rem; }

  /* Right column — form */
  .appt__formcol { width: 100%; }
  .ob-form { padding: clamp(24px, 3.5vw, 40px); }
  .ob-form__heading { font-family: var(--font-head); font-weight: 800; font-size: 1.3rem; color: var(--ink); margin: 0 0 22px; }
  .field-row { display: grid; gap: 18px; margin-bottom: 18px; }
  @media (min-width: 560px) { .field-row { grid-template-columns: 1fr 1fr; } }
  .field { display: flex; flex-direction: column; margin-bottom: 18px; }
  .field-row .field { margin-bottom: 0; }
  .ob-form label { font-family: var(--font-head); font-weight: 600; font-size: .92rem; color: var(--ink); margin-bottom: 8px; }
  .req { color: var(--coral); }
  .opt { font-weight: 400; color: var(--slate); }
  .ob-form input,
  .ob-form select,
  .ob-form textarea {
    width: 100%; font-family: var(--font-body); font-size: 1rem; color: var(--ink);
    padding: 13px 15px; border: 1px solid var(--line); border-radius: 12px; background: #fff;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .ob-form textarea { resize: vertical; }
  .ob-form input:focus,
  .ob-form select:focus,
  .ob-form textarea:focus {
    outline: none; border-color: var(--teal); box-shadow: 0 0 0 3px rgba(31, 120, 194, .18);
  }
  .consent { display: flex; gap: 12px; align-items: flex-start; margin: 4px 0 24px; }
  .consent input { width: 20px; height: 20px; flex: none; margin-top: 3px; accent-color: var(--teal); }
  .consent label { font-family: var(--font-body); font-weight: 400; font-size: .83rem; color: var(--slate); line-height: 1.55; margin: 0; }
  .ob-form .btn { width: 100%; justify-content: center; }
  .form-note { font-size: .85rem; color: var(--slate); text-align: center; margin: 16px 0 0; }
</style>
