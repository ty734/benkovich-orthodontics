---
import { site } from '../data/site';
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  crumbs?: { label: string; href: string }[];
  showCta?: boolean;
}
const { eyebrow, title, subtitle, image, imageAlt, crumbs, showCta = true } = Astro.props;
---
<section class:list={["page-hero", { "page-hero--split": image }]}>
  <div class="container">
    {crumbs && (
      <nav class="crumbs" aria-label="Breadcrumb">
        {crumbs.map((c, i) => (
          <>{i > 0 && <span class="crumbs__sep">/</span>}<a href={c.href}>{c.label}</a></>
        ))}
      </nav>
    )}
    <div class="page-hero__grid">
      <div class="page-hero__copy">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h1>{title}</h1>
        {subtitle && <p class="lead">{subtitle}</p>}
        {showCta && (
          <div class="page-hero__cta">
            <a href={site.booking} class="btn btn--primary">Schedule Free Exam</a>
            <a href={site.locations[0].phoneHref} class="btn btn--ghost">Call {site.locations[0].phone}</a>
          </div>
        )}
      </div>
      {image && (
        <div class="page-hero__media">
          <img src={image} alt={imageAlt ?? title} width="520" height="380" fetchpriority="high" />
        </div>
      )}
    </div>
  </div>
</section>
<style>
  .page-hero { background: radial-gradient(120% 130% at 85% 0%, var(--mint) 0%, #fff 58%); padding: clamp(34px, 5vw, 64px) 0 clamp(40px, 6vw, 70px); }
  .crumbs { font-size: .85rem; color: var(--slate); margin-bottom: 18px; }
  .crumbs a { color: var(--slate); font-weight: 600; }
  .crumbs a:hover { color: var(--teal-600); }
  .crumbs__sep { margin: 0 8px; opacity: .5; }
  .page-hero__grid { display: grid; gap: 40px; align-items: center; }
  .page-hero--split .page-hero__grid { grid-template-columns: 1fr; }
  @media (min-width: 920px) { .page-hero--split .page-hero__grid { grid-template-columns: 1.05fr .95fr; } }
  .page-hero__cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 24px; }
  .page-hero__media img { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow); object-fit: cover; aspect-ratio: 5/3.6; }
</style>
