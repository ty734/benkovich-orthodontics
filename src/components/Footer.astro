---
import { site } from '../data/site';
---
<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <img src="/images/logo.svg" alt={site.name + ' logo'} class="footer__logo" width="210" height="50" />
        <p>{site.tagline}</p>
        <p class="footer__stat">{site.patients} happy patients · {site.reviewCount} 5-star reviews · Since {site.established}</p>
        <div class="footer__social">
          <a href={site.social.facebook} aria-label="Benkovich Orthodontics on Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8v8.44C19.61 23.08 24 18.09 24 12.07Z"/></svg>
          </a>
          <a href={site.social.instagram} aria-label="Benkovich Orthodontics on Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.71 3.71 0 0 1-1.38-.9 3.71 3.71 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16ZM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.12 1.38C1.36 2.67.95 3.34.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13.66.66 1.33 1.07 2.12 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.87 5.87 0 0 0 2.13-1.38c.66-.66 1.07-1.33 1.38-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.87 5.87 0 0 0-1.38-2.13A5.87 5.87 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0Zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-10.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z"/></svg>
          </a>
          <a href={site.social.youtube} aria-label="Benkovich Orthodontics on YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.19C0 8.08 0 12 0 12s0 3.92.5 5.81a3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14C24 15.92 24 12 24 12s0-3.92-.5-5.81ZM9.6 15.6V8.4l6.24 3.6-6.24 3.6Z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h4>Treatments</h4>
        <a href="/braces/">Braces</a>
        <a href="/invisalign/">Invisalign®</a>
        <a href="/early-orthodontics/">Early Orthodontics</a>
        <a href="/adult-orthodontics/">Adult Orthodontics</a>
        <a href="/retainers/">Retainers</a>
      </div>

      <div class="footer__col">
        <h4>Practice</h4>
        <a href="/about/meet-dr-benkovich/">Meet Dr. Benkovich</a>
        <a href="/about/meet-the-team-dental/">Our Team</a>
        <a href="/patient-info/testimonials/">Reviews</a>
        <a href="/patient-info/financial-information/">Financial &amp; Insurance</a>
        <a href="/appointment-request/">New Patients</a>
      </div>

      <div class="footer__col footer__locations">
        <h4>Our Offices</h4>
        {site.locations.map((l) => (
          <div class="footer__loc">
            <strong>{l.name}</strong>
            <a href={l.phoneHref}>{l.phone}</a>
            <span>{l.address.join(', ')}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {site.established}–2026 {site.name}. All rights reserved.</span>
      <span class="footer__legal">
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/terms-and-conditions/">Terms &amp; Conditions</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--teal-900); color: #bcd4e6; padding: 64px 0 28px; font-size: .95rem; }
  .footer__top { display: grid; gap: 36px; grid-template-columns: 1fr; }
  .footer__brand p { color: #a3bdd4; max-width: 320px; }
  .footer__logo { height: 46px; width: auto; margin-bottom: 14px; filter: brightness(0) invert(1); opacity: .95; }
  .footer__stat { font-weight: 600; color: #eaf3fb !important; }
  .footer__social { display: flex; gap: 12px; margin-top: 16px; }
  .footer__social a { display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%; color: #eaf3fb;
    background: rgba(255,255,255,.1); transition: background .2s, color .2s, transform .2s; }
  .footer__social a:hover { background: #fff; color: var(--teal-900); transform: translateY(-2px); }
  .footer__social svg { display: block; }
  .footer__col h4 { color: #fff; font-size: 1rem; margin-bottom: 14px; }
  .footer__col a { display: block; color: #bcd4e6; padding: 5px 0; }
  .footer__col a:hover { color: #fff; }
  .footer__loc { margin-bottom: 14px; display: flex; flex-direction: column; }
  .footer__loc strong { color: #fff; }
  .footer__loc a { color: #8fd0ff; font-weight: 700; }
  .footer__bottom { display: flex; justify-content: space-between; gap: 14px; flex-wrap: wrap;
    margin-top: 44px; padding-top: 22px; border-top: 1px solid rgba(255,255,255,.12); color: #93b2cb; font-size: .85rem; }
  .footer__legal a { color: #93b2cb; margin-left: 16px; }
  .footer__legal a:hover { color: #fff; }
  @media (min-width: 760px) { .footer__top { grid-template-columns: 1.6fr 1fr 1fr 1.2fr; } }
</style>
