---
import { site, nav } from '../data/site';
---
<div class="topbar">
  <div class="container topbar__row">
    <span class="topbar__tag">Specialty-trained orthodontist caring for our community since {site.established}</span>
    <div class="topbar__links">
      <a href={site.locations[0].phoneHref}>Annapolis {site.locations[0].phone}</a>
      <span class="dot">•</span>
      <a href={site.locations[1].phoneHref}>Chester {site.locations[1].phone}</a>
    </div>
  </div>
</div>

<header class="site-header" id="siteHeader">
  <div class="container header__row">
    <a href="/" class="header__logo" aria-label={site.name}>
      <img src="/images/logo.svg" alt={site.name + ' logo'} width="190" height="46" />
    </a>

    <nav class="nav" aria-label="Primary">
      <ul class="nav__list">
        {nav.map((item) => (
          <li class={item.children ? 'has-children' : ''}>
            <a href={item.href}>{item.label}{item.children && <span class="caret">▾</span>}</a>
            {item.children && (
              <ul class="dropdown">
                {item.children.map((c) => <li><a href={c.href}>{c.label}</a></li>)}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__cta">
      <a href={site.locations[0].phoneHref} class="header__phone" aria-label="Call us">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13 1.05.36 2.07.7 3.06a2 2 0 0 1-.45 2.11L8.09 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.99.34 2.01.57 3.06.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
      <a href={site.booking} class="btn btn--primary">Schedule Free Exam</a>
      <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-menu" id="mobileMenu" hidden>
    <ul>
      {nav.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
          {item.children && <ul>{item.children.map((c) => <li><a href={c.href}>{c.label}</a></li>)}</ul>}
        </li>
      ))}
    </ul>
    <a href={site.booking} class="btn btn--primary btn--lg" style="margin:10px 0;">Schedule Free Exam</a>
  </div>
</header>

<style>
  .topbar { background: var(--navy); color: #cfe2f2; font-size: .82rem; }
  .topbar__row { display: flex; justify-content: space-between; align-items: center; min-height: 38px; gap: 18px; }
  .topbar__tag { opacity: .85; }
  .topbar__links { display: flex; align-items: center; gap: 12px; }
  .topbar__links a { color: #eaf3fb; font-weight: 600; }
  .topbar__links a:hover { color: #fff; }
  .topbar__portal { background: rgba(255,255,255,.12); padding: 4px 12px; border-radius: 999px; }
  .dot { opacity: .4; }
  @media (max-width: 880px) { .topbar__tag, .dot { display: none; } .topbar__row { justify-content: center; } }

  .site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,.96); backdrop-filter: blur(8px); border-bottom: 1px solid var(--line); }
  .header__row { display: flex; align-items: center; gap: 24px; min-height: 78px; }
  .header__logo img { height: 44px; width: auto; }
  .nav { margin-left: auto; }
  .nav__list { display: flex; gap: 4px; list-style: none; margin: 0; padding: 0; }
  .nav__list > li > a { display: inline-flex; align-items: center; gap: 4px; padding: 10px 14px; border-radius: 10px; color: var(--ink); font-family: var(--font-head); font-weight: 600; font-size: .98rem; }
  .nav__list > li > a:hover { background: var(--mint); color: var(--teal-700); }
  .caret { font-size: .7em; opacity: .6; }
  .has-children { position: relative; }
  .dropdown { position: absolute; top: 100%; left: 0; min-width: 230px; background: #fff; border: 1px solid var(--line);
    border-radius: 14px; box-shadow: var(--shadow); padding: 8px; list-style: none; margin: 8px 0 0; opacity: 0; visibility: hidden; transform: translateY(8px); transition: .18s ease; }
  .has-children:hover .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown a { display: block; padding: 9px 14px; border-radius: 9px; color: var(--ink); font-weight: 500; font-size: .95rem; }
  .dropdown a:hover { background: var(--mint); color: var(--teal-700); }

  .header__cta { display: flex; align-items: center; gap: 12px; }
  .header__phone { display: none; width: 44px; height: 44px; border-radius: 50%; background: var(--mint); color: var(--teal-700); align-items: center; justify-content: center; }
  .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: 0; padding: 8px; cursor: pointer; }
  .hamburger span { width: 26px; height: 3px; background: var(--teal-700); border-radius: 2px; transition: .2s; }

  .mobile-menu { display: none; border-top: 1px solid var(--line); padding: 14px 24px 24px; }
  .mobile-menu ul { list-style: none; margin: 0; padding: 0; }
  .mobile-menu > ul > li > a { display: block; padding: 12px 0; font-family: var(--font-head); font-weight: 700; font-size: 1.1rem; color: var(--ink); border-bottom: 1px solid var(--line); }
  .mobile-menu ul ul { padding: 4px 0 10px 14px; }
  .mobile-menu ul ul a { display: block; padding: 7px 0; color: var(--slate); }

  @media (max-width: 1080px) {
    .nav, .header__cta .btn--primary { display: none; }
    .header__phone { display: inline-flex; }
    .hamburger { display: flex; margin-left: auto; }
    .header__cta { margin-left: auto; }
    .mobile-menu.open { display: block; }
  }
</style>

<script>
  const h = document.getElementById('hamburger');
  const m = document.getElementById('mobileMenu');
  h?.addEventListener('click', () => {
    const open = m?.classList.toggle('open');
    if (m) m.hidden = !open;
    h.setAttribute('aria-expanded', String(open));
  });
</script>
